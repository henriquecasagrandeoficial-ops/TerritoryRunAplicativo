# =============================================================================
# Copie para `.env` (local) ou configure no painel Vercel / V0 (preview/produção).
# Não commite ficheiros `.env` com segredos.
# =============================================================================

# -----------------------------------------------------------------------------
# Desenvolvimento local (SQLite)
# -----------------------------------------------------------------------------
# Caminho relativo à raiz do projeto (após `npx prisma migrate dev`).
DATABASE_URL="file:./dev.db"

# Obrigatório para Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET=

# URL pública (local)
AUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect autorizado: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Apple (futuro) — descomente em auth.ts quando configurar
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=

# -----------------------------------------------------------------------------
# Preview / produção (V0, Vercel, etc.)
# -----------------------------------------------------------------------------
# Não use SQLite em ficheiro no servidor: o disco é efémero e não persiste entre
# deploys. Use PostgreSQL gerido, por exemplo:
#   - Neon (https://neon.tech)
#   - Supabase (https://supabase.com)
#   - Vercel Postgres
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
#
# AUTH_SECRET=<mesmo tipo de segredo que em local; obrigatório em produção>
#
# AUTH_URL=https://seu-dominio.vercel.app
# (URL exata do preview ou produção — usada em OAuth e links de reset)
#
# Após ligar o Postgres, na máquina de CI ou localmente com DATABASE_URL apontando
# para a base de produção:
#   npx prisma migrate deploy
#
# Checklist painel V0 / Vercel:
# [ ] AUTH_SECRET definido
# [ ] AUTH_URL igual à URL pública do deploy
# [ ] DATABASE_URL com PostgreSQL (não file:)
# [ ] AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET se usar login Google (redirect URI no Google Cloud)

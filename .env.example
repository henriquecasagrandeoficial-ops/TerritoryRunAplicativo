# Copie para `.env` e preencha. Não commite segredos.

# SQLite (dev) — ajuste o caminho se usar outro diretório
DATABASE_URL="file:./dev.db"

# Obrigatório para Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET=

# URL pública do app (usada em links de reset e OAuth)
AUTH_URL="http://localhost:3000"

# Google OAuth — Console: https://console.cloud.google.com/apis/credentials
# Redirect autorizado: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Apple (futuro) — descomente em auth.ts quando configurar
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=
